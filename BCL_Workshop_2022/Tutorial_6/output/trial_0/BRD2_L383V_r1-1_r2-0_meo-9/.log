            		<Reweight scoretype="fa_intra_rep" weight="0.004"/>
	            	<Reweight scoretype="fa_elec" weight="0.42"/>
        	    	<Reweight scoretype="hbond_bb_sc" weight="1.3"/>
            		<Reweight scoretype="hbond_sc" weight="1.3"/>
	        	<Reweight scoretype="rama" weight="0.2"/>
		</ScoreFunction>
    	</SCOREFXNS>
        <LIGAND_AREAS>
        </LIGAND_AREAS>
        <INTERFACE_BUILDERS>
        </INTERFACE_BUILDERS>
        <MOVEMAP_BUILDERS>
