		<ReadResfile name="rrf" filename="/home/ben/Projects/BCL_Workshop_2022/Tutorial_6/resfiles/V.resfile"/>
		<OperateOnResidueSubset name="repackonly_ligand" selector="ligand" >
                        <RestrictToRepackingRLT/>
