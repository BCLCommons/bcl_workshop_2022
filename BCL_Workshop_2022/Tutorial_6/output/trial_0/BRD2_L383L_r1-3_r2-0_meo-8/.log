                <Not name="not_interface" selector="interface"/> #Note: this selects only the parts of the protein far from the interface
        </RESIDUE_SELECTORS>
	<TASKOPERATIONS>
                # Turn off design but allow repacking
		<RestrictToRepacking name="rtrp"/>
