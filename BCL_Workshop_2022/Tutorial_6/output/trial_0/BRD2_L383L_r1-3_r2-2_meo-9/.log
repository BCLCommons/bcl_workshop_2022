		object_data_label="AddMedChem(
		ov_shuffle_h=false,ov_reverse=false,
		medchem_library=/home/ben/Projects/BCL_Workshop_2022/Tutorial_6/bump_medchem_fragments_r2/r2_2.sdf, 
		druglikeness_type=None,
		mutable_atoms=0)"
		/>

		<BCLFragmentMutateMover name="add_medchem_methoxy_scan" 
		ligand_chain="X" 
		object_data_label="AddMedChem(
		ov_shuffle_h=false,ov_reverse=false,
		medchem_library=/home/ben/Projects/BCL_Workshop_2022/Tutorial_6/methoxy_scan_fragment.sdf, 
		druglikeness_type=None,
		mutable_atoms=17)"
		/>

