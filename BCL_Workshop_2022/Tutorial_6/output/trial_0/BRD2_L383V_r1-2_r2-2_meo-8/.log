		sidechain="true" native="false" func_groups="false"/>
	
		# Minimization movers
		<MinMover name="min_soft" scorefxn="ligand_soft_rep" chi="true" bb="true" cartesian="false" type="lbfgs_armijo_nonmonotone"/>
