                <ParsedProtocol name="run_b" mode="sequence">
			<Add mover_name="mutate"/>
			<Add mover_name="min_cycle_soft"/>
			<Add mover_name="min_cycle_hard"/>
		        <Add mover_name="add_medchem_methoxy_scan"/>
