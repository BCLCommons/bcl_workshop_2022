        	        <Add filter_name="score_filter"/>
        	        <Add mover_name="add_scores"/>
                </ParsedProtocol>

                <RandomMover name="run"
                movers="run_a,run_b"
                weights="0.0,1.0"
                />

	</MOVERS>
	<APPLY_TO_POSE>
	</APPLY_TO_POSE>
	<PROTOCOLS>
        	<Add mover_name="run"/>
	</PROTOCOLS>
	<OUTPUT />
</ROSETTASCRIPTS>
