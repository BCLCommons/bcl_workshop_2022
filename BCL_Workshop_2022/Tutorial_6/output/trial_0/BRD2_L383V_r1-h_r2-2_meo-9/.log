		<ParsedProtocol mode="sequence" name="run_a">
			<Add mover_name="mutate"/>
			<Add mover_name="min_cycle_soft"/>
			<Add mover_name="min_cycle_hard"/>
			<Add mover_name="add_medchem_methoxy_scan"/>
			<Add mover_name="add_medchem_bump_r2"/>
			<Add mover_name="add_medchem_bump_r1"/>
			<Add mover_name="min_cycle_soft"/>
			<Add mover_name="min_cycle_hard"/>
			<Add mover_name="relax_cycle"/>
			<Add filter_name="score_filter"/>
			<Add mover_name="add_scores"/>
		</ParsedProtocol>
		<ParsedProtocol mode="sequence" name="run_b">
			<Add mover_name="mutate"/>
			<Add mover_name="min_cycle_soft"/>
			<Add mover_name="min_cycle_hard"/>
			<Add mover_name="add_medchem_methoxy_scan"/>
			<Add mover_name="add_medchem_bump_r2"/>
			<Add mover_name="min_cycle_soft"/>
			<Add mover_name="min_cycle_hard"/>
			<Add mover_name="relax_cycle"/>
			<Add filter_name="score_filter"/>
			<Add mover_name="add_scores"/>
		</ParsedProtocol>
		<RandomMover movers="run_a,run_b" name="run" weights="0.0,1.0"/>
	</MOVERS>
	<APPLY_TO_POSE/>
	<PROTOCOLS>
		<Add mover_name="run"/>
	</PROTOCOLS>
	<OUTPUT/>
</ROSETTASCRIPTS>
