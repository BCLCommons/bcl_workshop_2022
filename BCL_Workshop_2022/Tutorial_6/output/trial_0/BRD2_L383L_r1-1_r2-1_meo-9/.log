		<PackRotamersMover name="repack_interface" scorefxn="ligand_soft_rep" nloop="5" 
		task_operations="rtrp,repack_interface,fix_notinterface"/>
		
		# Relax
                <VirtualRoot name="root" removable="1" />
                <VirtualRoot name="remove" remove="1" />
