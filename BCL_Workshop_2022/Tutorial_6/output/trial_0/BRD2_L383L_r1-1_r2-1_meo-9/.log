                        <RestrictToRepackingRLT/>
                </OperateOnResidueSubset>
                <OperateOnResidueSubset name="fix_notinterface" selector="not_interface" >
                        <PreventRepackingRLT/>
                </OperateOnResidueSubset>
	</TASKOPERATIONS>
	<FILTERS>
		<LigInterfaceEnergy name="ifscore" scorefxn="hard_rep" include_cstE="0" energy_cutoff="0.0"/>
